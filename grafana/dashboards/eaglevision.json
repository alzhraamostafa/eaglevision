{
  "id": null,
  "uid": "eaglevision-main",
  "title": "EagleVision — Equipment Utilization",
  "tags": ["eaglevision", "construction", "cv"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Live Video Feed",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 10 },
      "options": {
        "mode": "html",
        "content": "<div style='width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#111;border-radius:4px;overflow:hidden'><img src='http://localhost:5000/stream' style='max-width:100%;max-height:100%;object-fit:contain' onerror=\"this.src='http://localhost:5000/frame'\" /></div>"
      }
    },

    {
      "id": 2,
      "title": "Active Machines Right Now",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 5 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT NOW() AS time, COUNT(DISTINCT equipment_id) AS \"Active Machines\" FROM equipment_events WHERE time > NOW() - INTERVAL '10 seconds' AND current_state = 'ACTIVE'",
          "format": "table"
        }
      ]
    },

    {
      "id": 3,
      "title": "Fleet Avg Utilization %",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 5 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green",  "value": 70 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT NOW() AS time, ROUND(AVG(utilization_pct)::numeric, 1) AS \"Fleet Utilization\" FROM equipment_events WHERE time > NOW() - INTERVAL '30 seconds'",
          "format": "table"
        }
      ]
    },

    {
      "id": 4,
      "title": "Machine States (last 10 s)",
      "type": "table",
      "gridPos": { "x": 12, "y": 5, "w": 8, "h": 5 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": { "sortBy": [{ "displayName": "Equipment", "desc": false }] },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT DISTINCT ON (equipment_id) equipment_id AS \"Equipment\", equipment_class AS \"Class\", current_state AS \"State\", current_activity AS \"Activity\", ROUND(utilization_pct::numeric, 1) AS \"Util %\", motion_source AS \"Motion\" FROM equipment_events WHERE time > NOW() - INTERVAL '10 seconds' ORDER BY equipment_id, time DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "ACTIVE":   { "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "INACTIVE": { "color": "blue",  "index": 1 } } }
                ]
              }
            ]
          }
        ]
      }
    },

    {
      "id": 5,
      "title": "Utilization % Over Time (per machine)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT time_bucket('10 seconds', time) AS time, equipment_id, AVG(utilization_pct) AS utilization FROM equipment_events WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },

    {
      "id": 6,
      "title": "Working vs Idle Time (seconds)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 10, "w": 8, "h": 8 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Active" },  "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Idle" },    "properties": [{ "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT NOW() AS time, MAX(total_active_sec) AS \"Active\", MAX(total_idle_sec) AS \"Idle\" FROM equipment_events WHERE $__timeFilter(time) GROUP BY equipment_id",
          "format": "table"
        }
      ]
    },

    {
      "id": 7,
      "title": "Activity Distribution (last 5 min)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 8 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT current_activity AS \"metric\", COUNT(*) AS \"value\" FROM equipment_events WHERE time > NOW() - INTERVAL '5 minutes' GROUP BY current_activity ORDER BY 2 DESC",
          "format": "table"
        }
      ]
    },

    {
      "id": 8,
      "title": "Motion Source Breakdown",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 8 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT motion_source AS \"metric\", COUNT(*) AS \"value\" FROM equipment_events WHERE time > NOW() - INTERVAL '5 minutes' GROUP BY motion_source",
          "format": "table"
        }
      ]
    },

    {
      "id": 9,
      "title": "Arm vs Tracks Motion Score (raw)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 8 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT time_bucket('5 seconds', time) AS time, equipment_id || ' arm'    AS metric, AVG(arm_region_score)    AS value FROM equipment_events WHERE $__timeFilter(time) GROUP BY 1,2 UNION ALL SELECT time_bucket('5 seconds', time) AS time, equipment_id || ' tracks' AS metric, AVG(tracks_region_score) AS value FROM equipment_events WHERE $__timeFilter(time) GROUP BY 1,2 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },

    {
      "id": 10,
      "title": "Events per Second (throughput)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 6 },
      "datasource": { "uid": "timescaledb-uid" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT time_bucket('5 seconds', time) AS time, COUNT(*) / 5.0 AS \"events/s\" FROM equipment_events WHERE $__timeFilter(time) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },

    {
      "id": 11,
      "title": "Confidence Score Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 6 },
      "datasource": { "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "timescaledb-uid" },
          "rawSql": "SELECT time_bucket('5 seconds', time) AS time, equipment_id, AVG(confidence) AS confidence FROM equipment_events WHERE $__timeFilter(time) GROUP BY 1,2 ORDER BY 1",
          "format": "time_series"
        }
      ]
    }

  ]
}
